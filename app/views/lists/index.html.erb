<div class="banner d-flex flex-column justify-content-center align-items-center" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('<%= image_path("cinemaisles.jpg") %>')">
  <h1>Cinema Watch Lists</h1>
  <h4>...Now and Later...</h4>
</div>

<div class="list_container d-flex flex-wrap justify-content-evenly">
  <% @lists.each do |list| %>
      <div class="list_card d-flex justify-content-center align-items-center" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('<%= cl_image_path list.photo.key, height: 300, crop: :fill %>')">
        <p><%= link_to list.name, list_path(list), class: "text-decoration-none text-white" %></p>
      </div>
  <% end %>
</div>

<div class="m-2 d-flex justify-content-center">
<%= link_to "Make a new list", new_list_path, class: "btn btn-secondary" %>
</div>
