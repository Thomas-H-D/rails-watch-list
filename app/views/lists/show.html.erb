<h1><%= @list.name %></h1>
<div class="d-flex justify-content-evenly">
  <% @list.bookmarks.each do |bookmark| %>
    <div class="movie_card">
      <%= image_tag "https://image.tmdb.org/t/p/w500#{bookmark.movie.poster_url}", alt: bookmark.movie.title, class: "movie_poster" %>
      <h3><%= bookmark.movie.title %></h3>
      <p><%= bookmark.movie.overview %></p>
      <p class="pt-3">Top comment:</p>
      <p><%= bookmark.comment %></p>
      <div class="pt-3 d-flex align-items-end">
        <%= link_to "Remove from List", bookmark_path(bookmark), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to remove this movie?" } %>
      </div>
    </div>
  <% end %>
</div>
<%= link_to "Add a bookmark", new_list_bookmark_path(@list) %>
<%= link_to "Back to Lists", lists_path  %>
<%= link_to "Delete List", list_path(@list), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
